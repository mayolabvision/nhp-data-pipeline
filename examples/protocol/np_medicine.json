            "win_scale_um": 300.0, 
            "motion_bound": 800, 
            "time_kernel_width": 20,
            "method": "medicine" 
        },
        "interpolate_motion_kwargs":{
            "border_mode": "force_extrapolate"
        }
    },
    
    "sorting":{
        "sorter_name": "kilosort4",
        "do_correction": false,
        "Th_universal": 9,
        "Th_learned": 8,
        "whitening_range": 12,
        "dminx": 32,
        "ccg_threshold": 0.25 
