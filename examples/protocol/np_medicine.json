        },
        "waveforms": {
            "ms_before": 1.5, 
            "ms_after": 2
        },
        "principal_components": {},
        "templates": {
            "operators": ["average", "median", "std"]
        },
        "amplitude_scalings": {},
        "spike_amplitudes": {},
