{
    "preprocessing": {
        "highpass_filter": {
            "freq_min": 300, 
            "dtype": "int16"
        },
        "detect_and_remove_bad_channels": {},
        "phase_shift": {},
        "common_reference": {
            "operator": "median", 
            "reference": "global"
        }
    },

    "motion_correction": {
        "preprocessing": {
            "bandpass_filter": {
                "freq_min": 300, 
                "freq_max": 5000, 
                "dtype": "int16"
            },
            "detect_and_remove_bad_channels": {},
            "phase_shift": {},
            "common_reference": {
                "operator": "median", 
                "reference": "global"
            }
        },
        "detect_kwargs": {},
        "localize_peaks_kwargs": {},
