    "quality_metrics":{
        "num_spikes": {},
        "firing_rate": {},
        "presence_ratio": {},
        "snr": {},
        "isi_violation": {},
        "rp_violation": {},
        "sliding_rp_violation": {},
        "amplitude_cutoff": {},
        "amplitude_median": {},
        "amplitude_cv": {},
        "synchrony": {},
        "firing_range": {},
