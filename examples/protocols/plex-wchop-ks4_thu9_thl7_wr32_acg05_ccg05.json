{
    "motion_screening": {
        "enabled": false
    },
    
    "preprocessing": {
        "highpass_filter": {
            "freq_min": 300, 
            "dtype": "int16"
        },
        "common_reference": {
            "operator": "median", 
            "reference": "global"
        }
    },

    "motion_correction": {},
    
    "sorting":{
        "sorter_name": "kilosort4",
        "do_correction": false,
        "Th_universal": 9,
        "Th_learned": 7,
        "whitening_range": 32,
        "dminx": 32,
        "nearest_templates": 32,
        "acg_threshold": 0.05,
        "ccg_threshold": 0.05 
    },

    "postprocessing":{
        "isi_histograms": {},
        "correlograms": {},
        "acgs_3d": {},
        "noise_levels": {},
        "random_spikes": {
            "method": "uniform", 
            "max_spikes_per_unit": 500 
        },
        "waveforms": {
            "ms_before": 1.5, 
            "ms_after": 2
        },
        "templates": {
            "operators": ["average", "median", "std"]
        },
        "amplitude_scalings": {},
        "spike_amplitudes": {},
        "spike_locations": {},
        "template_metrics": {
            "include_multi_channel_metrics": true
        },
        "template_similarity": {},
        "unit_locations": {}
    },

    "quality_metrics":{
        "num_spikes": {},
        "firing_rate": {},
        "presence_ratio": {},
        "snr": {},
        "isi_violation": {},
        "rp_violation": {},
        "sliding_rp_violation": {},
        "amplitude_cutoff": {},
        "amplitude_median": {},
        "amplitude_cv": {},
        "synchrony": {},
        "firing_range": {},
        "drift": {},
        "sd_ratio": {},
        "noise_cutoff": {}
    } 
}
